{
  "name": "image-workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "dev": "npm run build && wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name image-workbench",
    "backend": "node backend/server.mjs",
    "backend:migrate": "node backend/migrate-d1.mjs",
    "backend:pm2:start": "pm2 start ecosystem.config.cjs --update-env",
    "backend:pm2:restart": "pm2 restart image-workbench-backend --update-env"
  },
  "devDependencies": {
    "pm2": "^6.0.14",
    "wrangler": "^4.0.0"
  }
}
